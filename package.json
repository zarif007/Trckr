{
  "name": "trckr",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest --config vitest.unit.config.ts",
    "test:ui": "vitest --config vitest.ui.config.ts",
    "test:run": "vitest run --config vitest.unit.config.ts && vitest run --config vitest.ui.config.ts",
    "docs:generate": "node scripts/docs/generate-file-map.mjs && node scripts/docs/generate-route-map.mjs && node scripts/docs/generate-docs-index.mjs",
    "docs:index:generate": "node scripts/docs/generate-docs-index.mjs",
    "docs:links:check": "node scripts/docs/check-doc-links.mjs",
    "docs:check": "node scripts/docs/check-docs-coverage.mjs && node scripts/docs/check-doc-links.mjs",
    "aligned:check": "node scripts/check-alignment.mjs",
    "size:check": "node scripts/check-file-size.mjs",
    "quality:check": "npm run aligned:check",
    "prepare": "husky",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "knip": "knip --include files,unlisted"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.4",
    "@ai-sdk/react": "^3.0.41",
    "@auth/prisma-adapter": "^2.11.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^6.0.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.27.1",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "prisma": "^6.19.2",
    "react": "19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.6.4",
    "react-rnd": "^10.5.3",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "happy-dom": "^15.11.7",
    "husky": "^9.1.7",
    "knip": "^5.88.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^4.2.1",
    "vitest": "^1.6.1"
  }
}
