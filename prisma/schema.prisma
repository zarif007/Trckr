// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String          @id @default(cuid())
  name                String?
  email               String?         @unique
  emailVerified       DateTime?
  image               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  accounts            Account[]
  llmTokenUsages      LlmTokenUsage[]
  loginEvents         LoginEvent[]
  projects            Project[]
  reports             Report[]
  analyses            Analysis[]
  sessions            Session[]
  authoredTrackerData TrackerData[]   @relation("TrackerDataAuthor")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Project {
  id             String          @id @default(cuid())
  userId         String
  name           String?
  settings       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  llmTokenUsages LlmTokenUsage[]
  modules        Module[]
  reports        Report[]
  analyses       Analysis[]
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackerSchemas TrackerSchema[]

  @@index([userId])
}

model Module {
  id             String          @id @default(cuid())
  projectId      String
  parentId       String?
  name           String?
  settings       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  parent         Module?         @relation("ModuleHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       Module[]        @relation("ModuleHierarchy")
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reports        Report[]
  analyses       Analysis[]
  trackerSchemas TrackerSchema[]

  @@index([projectId])
  @@index([parentId])
}

model TrackerSchema {
  id              String            @id @default(cuid())
  projectId       String
  moduleId        String?
  name            String?
  type            TrackerSchemaType @default(GENERAL)
  systemType      SystemFileType?
  instance        Instance          @default(SINGLE)
  versionControl  Boolean           @default(false)
  autoSave        Boolean           @default(true)
  /// If set, this schema is the ".list" companion for the referenced parent schema (MULTI instance only)
  listForSchemaId String?           @unique
  schema          Json
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  conversations   Conversation[]
  llmTokenUsages  LlmTokenUsage[]
  reports         Report[]
  analyses        Analysis[]
  trackerData     TrackerData[]
  listForSchema   TrackerSchema?    @relation("ListCompanion", fields: [listForSchemaId], references: [id], onDelete: Cascade)
  listCompanion   TrackerSchema?    @relation("ListCompanion")
  module          Module?           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, moduleId, systemType])
  @@index([projectId])
  @@index([moduleId])
}

enum ReportDefinitionStatus {
  draft
  ready
  error
}

enum ReportRunTrigger {
  initial
  refresh
}

enum ReportRunStatus {
  running
  completed
  failed
}

model Report {
  id              String          @id @default(cuid())
  projectId       String
  moduleId        String?
  userId          String
  name            String
  trackerSchemaId String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  llmTokenUsages  LlmTokenUsage[]
  module          Module?         @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  trackerSchema   TrackerSchema   @relation(fields: [trackerSchemaId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  definition      ReportDefinition?
  runs            ReportRun[]

  @@index([projectId])
  @@index([userId])
  @@index([trackerSchemaId])
  @@index([moduleId])
}

model ReportDefinition {
  id                String                 @id @default(cuid())
  reportId          String                 @unique
  userPrompt        String                 @default("")
  intent            Json?
  queryPlan         Json?
  /// Per-row ExprNode-derived columns (report calc agent); replay applies before formatter.
  calcPlan          Json?
  formatterPlan     Json?
  definitionVersion Int                    @default(1)
  schemaFingerprint String?
  status            ReportDefinitionStatus @default(draft)
  readyAt           DateTime?
  lastError         String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  report            Report                 @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model ReportRun {
  id         String           @id @default(cuid())
  reportId   String
  trigger    ReportRunTrigger
  status     ReportRunStatus  @default(running)
  startedAt  DateTime         @default(now())
  finishedAt DateTime?
  report     Report           @relation(fields: [reportId], references: [id], onDelete: Cascade)
  events     ReportRunEvent[]

  @@index([reportId])
}

model ReportRunEvent {
  id            String    @id @default(cuid())
  reportRunId   String
  seq           Int
  eventType     String
  phase         String?
  payload       Json?
  createdAt     DateTime  @default(now())
  reportRun     ReportRun @relation(fields: [reportRunId], references: [id], onDelete: Cascade)

  @@unique([reportRunId, seq])
  @@index([reportRunId])
}

model Analysis {
  id              String          @id @default(cuid())
  projectId       String
  moduleId        String?
  userId          String
  name            String
  trackerSchemaId String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  llmTokenUsages  LlmTokenUsage[]
  module          Module?         @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  trackerSchema   TrackerSchema   @relation(fields: [trackerSchemaId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  definition      AnalysisDefinition?
  runs            AnalysisRun[]

  @@index([projectId])
  @@index([userId])
  @@index([trackerSchemaId])
  @@index([moduleId])
}

model AnalysisDefinition {
  id                String                 @id @default(cuid())
  analysisId        String                 @unique
  userPrompt        String                 @default("")
  outline           Json?
  queryPlan         Json?
  document          Json?
  definitionVersion Int                    @default(1)
  schemaFingerprint String?
  status            ReportDefinitionStatus @default(draft)
  readyAt           DateTime?
  lastError         String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  analysis          Analysis               @relation(fields: [analysisId], references: [id], onDelete: Cascade)
}

model AnalysisRun {
  id         String           @id @default(cuid())
  analysisId String
  trigger    ReportRunTrigger
  status     ReportRunStatus  @default(running)
  startedAt  DateTime         @default(now())
  finishedAt DateTime?
  analysis   Analysis         @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  events     AnalysisRunEvent[]

  @@index([analysisId])
}

model AnalysisRunEvent {
  id            String      @id @default(cuid())
  analysisRunId String
  seq           Int
  eventType     String
  phase         String?
  payload       Json?
  createdAt     DateTime    @default(now())
  analysisRun   AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@unique([analysisRunId, seq])
  @@index([analysisRunId])
}

model LlmTokenUsage {
  id               String         @id @default(cuid())
  userId           String
  projectId        String?
  trackerSchemaId  String?
  reportId         String?
  analysisId       String?
  source           String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  createdAt        DateTime       @default(now())
  project          Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  report           Report?        @relation(fields: [reportId], references: [id], onDelete: SetNull)
  analysis         Analysis?      @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  trackerSchema    TrackerSchema? @relation(fields: [trackerSchemaId], references: [id], onDelete: SetNull)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, projectId])
  @@index([userId, trackerSchemaId])
  @@index([userId, trackerSchemaId, reportId])
  @@index([userId, trackerSchemaId, analysisId])
  @@index([createdAt])
}

model TrackerData {
  id              String        @id @default(cuid())
  trackerSchemaId String
  label           String?
  formStatus      String?
  data            Json
  /// Branch name for version-controlled trackers (default "main")
  branchName      String        @default("main")
  /// User who created/owns this branch or instance
  authorId        String?
  /// For VC branches: which TrackerData record this was branched from
  basedOnId       String?
  /// Whether this branch has been merged into main
  isMerged        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  author          User?         @relation("TrackerDataAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  basedOn         TrackerData?  @relation("BranchLineage", fields: [basedOnId], references: [id], onDelete: SetNull)
  derivedBranches TrackerData[] @relation("BranchLineage")
  trackerSchema   TrackerSchema @relation(fields: [trackerSchemaId], references: [id], onDelete: Cascade)

  @@index([trackerSchemaId])
  @@index([authorId])
  @@index([basedOnId])
}

model Conversation {
  id              String           @id @default(cuid())
  trackerSchemaId String
  title           String?
  mode            ConversationMode @default(BUILDER)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  trackerSchema   TrackerSchema    @relation(fields: [trackerSchemaId], references: [id], onDelete: Cascade)
  messages        Message[]

  @@index([trackerSchemaId])
}

model Message {
  id                    String       @id @default(cuid())
  conversationId        String
  role                  Role
  content               String
  trackerSchemaSnapshot Json?
  managerData           Json?
  /// Master data binding pass: reuse/create actions + ids (module/project scope).
  masterDataBuildResult Json?
  createdAt             DateTime     @default(now())
  conversation          Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolCalls             ToolCall[]

  @@index([conversationId])
}

model ToolCall {
  id          String         @id @default(cuid())
  messageId   String
  purpose     String
  fieldPath   String
  description String
  status      ToolCallStatus @default(pending)
  error       String?
  result      Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  message     Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

enum Instance {
  SINGLE
  MULTI
}

enum Role {
  USER
  ASSISTANT
}

enum TrackerSchemaType {
  GENERAL
  SYSTEM
}

enum SystemFileType {
  TEAMS
  SETTINGS
  RULES
  CONNECTIONS
}

enum ConversationMode {
  BUILDER
  ANALYST
}

enum ToolCallStatus {
  pending
  running
  done
  error
}
