// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(cuid())
  name            String?
  email           String?         @unique
  emailVerified   DateTime?
  image           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  accounts        Account[]
  llmTokenUsages  LlmTokenUsage[]
  loginEvents     LoginEvent[]
  projects        Project[]
  reports         Report[]
  analyses        Analysis[]
  sessions        Session[]
  createdGridRows GridRow[]       @relation("GridRowCreator")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Project {
  id             String          @id @default(cuid())
  userId         String
  name           String?
  settings       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  llmTokenUsages LlmTokenUsage[]
  modules        Module[]
  reports        Report[]
  analyses       Analysis[]
  workflows      Workflow[]
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackerSchemas TrackerSchema[]

  @@index([userId])
}

model Module {
  id             String          @id @default(cuid())
  projectId      String
  parentId       String?
  name           String?
  settings       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  parent         Module?         @relation("ModuleHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       Module[]        @relation("ModuleHierarchy")
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reports        Report[]
  analyses       Analysis[]
  trackerSchemas TrackerSchema[]
  workflows      Workflow[]

  @@index([projectId])
  @@index([parentId])
}

model TrackerSchema {
  id              String            @id @default(cuid())
  projectId       String
  moduleId        String?
  name            String?
  type            TrackerSchemaType @default(GENERAL)
  systemType      SystemFileType?
  instance        Instance          @default(SINGLE)
  versionControl  Boolean           @default(false)
  autoSave        Boolean           @default(true)
  /// If set, this schema is the ".list" companion for the referenced parent schema (MULTI instance only)
  listForSchemaId String?           @unique
  /// Tracker-level metadata: formActions, masterDataScope, masterDataMeta, dynamicConnectors
  meta            Json?
  schemaVersion   Int               @default(1)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  nodes           TrackerNode[]
  fields          TrackerField[]
  layoutNodes     TrackerLayoutNode[]
  bindings        TrackerBinding[]
  validations     TrackerValidation[]
  calculations    TrackerCalculation[]
  dynamicOptions  TrackerDynamicOption[]
  fieldRules      TrackerFieldRule[]
  gridRows        GridRow[]
  cache           TrackerSchemaCache?

  conversations   Conversation[]
  llmTokenUsages  LlmTokenUsage[]
  reports         Report[]
  analyses        Analysis[]
  listForSchema   TrackerSchema?    @relation("ListCompanion", fields: [listForSchemaId], references: [id], onDelete: Cascade)
  listCompanion   TrackerSchema?    @relation("ListCompanion")
  module          Module?           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, moduleId, systemType])
  @@index([projectId])
  @@index([moduleId])
}

enum ReportDefinitionStatus {
  draft
  ready
  error
}

enum ReportRunTrigger {
  initial
  refresh
}

enum ReportRunStatus {
  running
  completed
  failed
}

model Report {
  id              String          @id @default(cuid())
  projectId       String
  moduleId        String?
  userId          String
  name            String
  trackerSchemaId String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  llmTokenUsages  LlmTokenUsage[]
  module          Module?         @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  trackerSchema   TrackerSchema   @relation(fields: [trackerSchemaId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  definition      ReportDefinition?
  runs            ReportRun[]

  @@index([projectId])
  @@index([userId])
  @@index([trackerSchemaId])
  @@index([moduleId])
}

model ReportDefinition {
  id                String                 @id @default(cuid())
  reportId          String                 @unique
  userPrompt        String                 @default("")
  intent            Json?
  queryPlan         Json?
  /// Per-row ExprNode-derived columns (report calc agent); replay applies before formatter.
  calcPlan          Json?
  formatterPlan     Json?
  definitionVersion Int                    @default(1)
  schemaFingerprint String?
  status            ReportDefinitionStatus @default(draft)
  readyAt           DateTime?
  lastError         String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  report            Report                 @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model ReportRun {
  id         String           @id @default(cuid())
  reportId   String
  trigger    ReportRunTrigger
  status     ReportRunStatus  @default(running)
  startedAt  DateTime         @default(now())
  finishedAt DateTime?
  report     Report           @relation(fields: [reportId], references: [id], onDelete: Cascade)
  events     ReportRunEvent[]

  @@index([reportId])
}

model ReportRunEvent {
  id            String    @id @default(cuid())
  reportRunId   String
  seq           Int
  eventType     String
  phase         String?
  payload       Json?
  createdAt     DateTime  @default(now())
  reportRun     ReportRun @relation(fields: [reportRunId], references: [id], onDelete: Cascade)

  @@unique([reportRunId, seq])
  @@index([reportRunId])
}

model Analysis {
  id              String          @id @default(cuid())
  projectId       String
  moduleId        String?
  userId          String
  name            String
  trackerSchemaId String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  llmTokenUsages  LlmTokenUsage[]
  module          Module?         @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  trackerSchema   TrackerSchema   @relation(fields: [trackerSchemaId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  definition      AnalysisDefinition?
  runs            AnalysisRun[]

  @@index([projectId])
  @@index([userId])
  @@index([trackerSchemaId])
  @@index([moduleId])
}

model AnalysisDefinition {
  id                String                 @id @default(cuid())
  analysisId        String                 @unique
  userPrompt        String                 @default("")
  outline           Json?
  queryPlan         Json?
  document          Json?
  definitionVersion Int                    @default(1)
  schemaFingerprint String?
  status            ReportDefinitionStatus @default(draft)
  readyAt           DateTime?
  lastError         String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  analysis          Analysis               @relation(fields: [analysisId], references: [id], onDelete: Cascade)
}

model AnalysisRun {
  id         String           @id @default(cuid())
  analysisId String
  trigger    ReportRunTrigger
  status     ReportRunStatus  @default(running)
  startedAt  DateTime         @default(now())
  finishedAt DateTime?
  analysis   Analysis         @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  events     AnalysisRunEvent[]

  @@index([analysisId])
}

model AnalysisRunEvent {
  id            String      @id @default(cuid())
  analysisRunId String
  seq           Int
  eventType     String
  phase         String?
  payload       Json?
  createdAt     DateTime    @default(now())
  analysisRun   AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@unique([analysisRunId, seq])
  @@index([analysisRunId])
}

model LlmTokenUsage {
  id               String         @id @default(cuid())
  userId           String
  projectId        String?
  trackerSchemaId  String?
  reportId         String?
  analysisId       String?
  source           String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  createdAt        DateTime       @default(now())
  project          Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  report           Report?        @relation(fields: [reportId], references: [id], onDelete: SetNull)
  analysis         Analysis?      @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  trackerSchema    TrackerSchema? @relation(fields: [trackerSchemaId], references: [id], onDelete: SetNull)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, projectId])
  @@index([userId, trackerSchemaId])
  @@index([userId, trackerSchemaId, reportId])
  @@index([userId, trackerSchemaId, analysisId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Normalized tracker schema tables
// ---------------------------------------------------------------------------

enum NodeType {
  TAB
  SECTION
  GRID
}

model TrackerNode {
  id        String   @id @default(cuid())
  trackerId String
  type      NodeType
  /// Semantic identifier unique within a tracker (e.g. "overview_tab", "tasks_grid")
  slug      String
  name      String
  placeId   Int
  parentId  String?
  config    Json?
  /// Grid-only: array of view objects (table, kanban, etc.)
  views     Json?

  tracker        TrackerSchema        @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  parent         TrackerNode?         @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       TrackerNode[]        @relation("NodeHierarchy")
  layoutNodes    TrackerLayoutNode[]
  gridRows       GridRow[]
  sourceBindings TrackerBinding[]     @relation("BindingSourceGrid")
  targetBindings TrackerBinding[]     @relation("BindingTargetGrid")
  validations    TrackerValidation[]
  calculations   TrackerCalculation[]
  dynamicOptions TrackerDynamicOption[]
  fieldRules     TrackerFieldRule[]

  @@unique([trackerId, slug])
  @@index([trackerId])
  @@index([parentId])
  @@index([trackerId, type])
}

model TrackerField {
  id        String  @id @default(cuid())
  trackerId String
  /// Semantic identifier unique within a tracker (e.g. "task_name", "priority")
  slug      String
  dataType  String
  ui        Json
  config    Json?

  tracker        TrackerSchema        @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  layoutNodes    TrackerLayoutNode[]
  sourceBindings TrackerBinding[]     @relation("BindingSourceField")
  targetBindings TrackerBinding[]     @relation("BindingTargetField")
  validations    TrackerValidation[]
  calculations   TrackerCalculation[]
  dynamicOptions TrackerDynamicOption[]
  fieldRules     TrackerFieldRule[]
  rowReferences  GridRowReference[]

  @@unique([trackerId, slug])
  @@index([trackerId])
}

model TrackerLayoutNode {
  id        String  @id @default(cuid())
  trackerId String
  gridId    String
  fieldId   String
  order     Float
  /// Row index for div (form) grid layout
  row       Int?
  /// Column index for div (form) grid layout (max 3 per row)
  col       Int?
  renderAs  String?

  tracker TrackerSchema @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  grid    TrackerNode   @relation(fields: [gridId], references: [id], onDelete: Cascade)
  field   TrackerField  @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([gridId, fieldId])
  @@index([trackerId])
  @@index([gridId])
  @@index([fieldId])
  @@index([trackerId, gridId])
}

model TrackerBinding {
  id            String  @id @default(cuid())
  trackerId     String
  /// Nullable for foreign (cross-tracker) bindings
  sourceGridId  String?
  sourceFieldId String?
  targetGridId  String
  targetFieldId String
  /// fieldMappings, optionsSourceSchemaId, optionsSourceKey, etc.
  config        Json

  tracker     TrackerSchema @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  sourceGrid  TrackerNode?  @relation("BindingSourceGrid", fields: [sourceGridId], references: [id], onDelete: SetNull)
  sourceField TrackerField? @relation("BindingSourceField", fields: [sourceFieldId], references: [id], onDelete: SetNull)
  targetGrid  TrackerNode   @relation("BindingTargetGrid", fields: [targetGridId], references: [id], onDelete: Cascade)
  targetField TrackerField  @relation("BindingTargetField", fields: [targetFieldId], references: [id], onDelete: Cascade)

  @@unique([targetGridId, targetFieldId])
  @@index([trackerId])
  @@index([sourceGridId])
  @@index([targetGridId])
  @@index([trackerId, targetGridId])
}

model TrackerValidation {
  id        String @id @default(cuid())
  trackerId String
  gridId    String
  fieldId   String
  rules     Json

  tracker TrackerSchema @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  grid    TrackerNode   @relation(fields: [gridId], references: [id], onDelete: Cascade)
  field   TrackerField  @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([gridId, fieldId])
  @@index([trackerId])
}

model TrackerCalculation {
  id         String @id @default(cuid())
  trackerId  String
  gridId     String
  fieldId    String
  expression Json

  tracker TrackerSchema @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  grid    TrackerNode   @relation(fields: [gridId], references: [id], onDelete: Cascade)
  field   TrackerField  @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([gridId, fieldId])
  @@index([trackerId])
}

model TrackerDynamicOption {
  id         String @id @default(cuid())
  trackerId  String
  gridId     String
  fieldId    String
  definition Json

  tracker TrackerSchema @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  grid    TrackerNode   @relation(fields: [gridId], references: [id], onDelete: Cascade)
  field   TrackerField  @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([gridId, fieldId])
  @@index([trackerId])
}

model TrackerFieldRule {
  id        String @id @default(cuid())
  trackerId String
  gridId    String
  fieldId   String
  config    Json

  tracker TrackerSchema @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  grid    TrackerNode   @relation(fields: [gridId], references: [id], onDelete: Cascade)
  field   TrackerField  @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([gridId, fieldId])
  @@index([trackerId])
}

// ---------------------------------------------------------------------------
// Data layer: per-row storage replacing TrackerData
// ---------------------------------------------------------------------------

model GridRow {
  id            String    @id @default(cuid())
  trackerId     String
  gridId        String
  data          Json      @default("{}")
  schemaVersion String
  version       Int       @default(1)
  statusTag     String?
  sortOrder     Float     @default(0)
  branchName    String    @default("main")
  isMerged      Boolean   @default(false)
  deletedAt     DateTime?
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tracker       TrackerSchema    @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  grid          TrackerNode      @relation(fields: [gridId], references: [id], onDelete: Cascade)
  createdByUser User?            @relation("GridRowCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  outgoingRefs  GridRowReference[] @relation("RefFrom")
  incomingRefs  GridRowReference[] @relation("RefTo")

  @@index([trackerId])
  @@index([gridId])
  @@index([gridId, branchName])
  @@index([deletedAt])
  @@index([trackerId, deletedAt, branchName, updatedAt])
  @@index([trackerId, statusTag])
}

model GridRowReference {
  fromRowId   String
  fromFieldId String
  toRowId     String
  deletedAt   DateTime?

  fromRow   GridRow      @relation("RefFrom", fields: [fromRowId], references: [id], onDelete: Cascade)
  fromField TrackerField @relation(fields: [fromFieldId], references: [id], onDelete: Cascade)
  toRow     GridRow      @relation("RefTo", fields: [toRowId], references: [id], onDelete: Cascade)

  @@id([fromRowId, fromFieldId])
  @@index([toRowId])
  @@index([deletedAt])
}

// ---------------------------------------------------------------------------
// Schema cache for performance optimization
// ---------------------------------------------------------------------------

model TrackerSchemaCache {
  id            String   @id @default(cuid())
  trackerId     String   @unique
  schemaVersion Int
  assembledJson Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tracker TrackerSchema @relation(fields: [trackerId], references: [id], onDelete: Cascade)

  @@index([trackerId, schemaVersion])
}

// ---------------------------------------------------------------------------
// Conversations
// ---------------------------------------------------------------------------

model Conversation {
  id              String           @id @default(cuid())
  trackerSchemaId String
  title           String?
  mode            ConversationMode @default(BUILDER)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  trackerSchema   TrackerSchema    @relation(fields: [trackerSchemaId], references: [id], onDelete: Cascade)
  messages        Message[]

  @@index([trackerSchemaId])
}

model Message {
  id                    String       @id @default(cuid())
  conversationId        String
  role                  Role
  content               String
  trackerSchemaSnapshot Json?
  managerData           Json?
  /// Master data binding pass: reuse/create actions + ids (module/project scope).
  masterDataBuildResult Json?
  createdAt             DateTime     @default(now())
  conversation          Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolCalls             ToolCall[]

  @@index([conversationId])
}

model ToolCall {
  id          String         @id @default(cuid())
  messageId   String
  purpose     String
  fieldPath   String
  description String
  status      ToolCallStatus @default(pending)
  error       String?
  result      Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  message     Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

enum Instance {
  SINGLE
  MULTI
}

enum Role {
  USER
  ASSISTANT
}

enum TrackerSchemaType {
  GENERAL
  SYSTEM
}

enum SystemFileType {
  TEAMS
  SETTINGS
  RULES
  CONNECTIONS
}

enum ConversationMode {
  BUILDER
  ANALYST
}

enum ToolCallStatus {
  pending
  running
  done
  error
}

enum WorkflowRunStatus {
  pending
  running
  completed
  failed
  skipped
}

model Workflow {
  id          String        @id @default(cuid())
  projectId   String
  moduleId    String?
  name        String
  description String?
  enabled     Boolean       @default(true)
  schema      Json
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  module      Module?       @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  runs        WorkflowRun[]

  @@index([projectId])
  @@index([moduleId])
}

model WorkflowRun {
  id         String            @id @default(cuid())
  workflowId String
  status     WorkflowRunStatus @default(pending)
  trigger    Json
  startedAt  DateTime          @default(now())
  finishedAt DateTime?
  error      String?
  workflow   Workflow          @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  steps      WorkflowRunStep[]

  @@index([workflowId])
  @@index([status])
}

model WorkflowRunStep {
  id         String            @id @default(cuid())
  runId      String
  nodeId     String
  status     WorkflowRunStatus @default(pending)
  inputData  Json?
  outputData Json?
  startedAt  DateTime?
  finishedAt DateTime?
  error      String?
  run        WorkflowRun       @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}
