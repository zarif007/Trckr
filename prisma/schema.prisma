// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- NextAuth (Auth.js) Prisma adapter models ----
// https://authjs.dev/reference/adapter/prisma

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts             Account[]
  sessions             Session[]
  loginEvents          LoginEvent[]
  projects             Project[]
  authoredTrackerData  TrackerData[] @relation("TrackerDataAuthor")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// ---- App: log where/how user signed in (IP, user agent, etc.) ----

model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ---- App: projects, tracker schemas, data, conversations ----

enum Instance {
  SINGLE
  MULTI
}

enum Role {
  USER
  ASSISTANT
}

enum TrackerSchemaType {
  GENERAL
  SYSTEM
}

enum SystemFileType {
  TEAMS
  SETTINGS
  RULES
  CONNECTIONS
}

enum ConversationMode {
  BUILDER
  ANALYST
}

model Project {
  id             String        @id @default(cuid())
  userId         String
  name           String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackerSchemas TrackerSchema[]
  modules        Module[]

  @@index([userId])
}

model Module {
  id             String         @id @default(cuid())
  projectId      String
  parentId       String?
  name           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent         Module?        @relation("ModuleHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       Module[]       @relation("ModuleHierarchy")
  trackerSchemas TrackerSchema[]

  @@index([projectId])
  @@index([parentId])
}

model TrackerSchema {
  id               String       @id @default(cuid())
  projectId        String
  moduleId         String?
  name             String?
  type             TrackerSchemaType @default(GENERAL)
  systemType       SystemFileType?
  instance         Instance     @default(SINGLE)
  versionControl   Boolean      @default(false)
  autoSave         Boolean      @default(true)
  /// If set, this schema is the ".list" companion for the referenced parent schema (MULTI instance only)
  listForSchemaId  String?      @unique
  schema           Json
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  module           Module?      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  /// The parent schema this is a list companion for (null if this is not a .list schema)
  listForSchema    TrackerSchema? @relation("ListCompanion", fields: [listForSchemaId], references: [id], onDelete: Cascade)
  /// The .list companion schema (null if this schema has no list companion)
  listCompanion    TrackerSchema? @relation("ListCompanion")
  trackerData      TrackerData[]
  conversations    Conversation[]

  @@index([projectId])
  @@index([moduleId])
  @@unique([projectId, moduleId, systemType])
}

model TrackerData {
  id               String        @id @default(cuid())
  trackerSchemaId  String
  label            String?
  formStatus       String?
  data             Json
  /// Branch name for version-controlled trackers (default "main")
  branchName       String        @default("main")
  /// User who created/owns this branch or instance
  authorId         String?
  /// For VC branches: which TrackerData record this was branched from
  basedOnId        String?
  /// Whether this branch has been merged into main
  isMerged         Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  trackerSchema    TrackerSchema @relation(fields: [trackerSchemaId], references: [id], onDelete: Cascade)
  author           User?         @relation("TrackerDataAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  basedOn          TrackerData?  @relation("BranchLineage", fields: [basedOnId], references: [id], onDelete: SetNull)
  derivedBranches  TrackerData[] @relation("BranchLineage")

  @@index([trackerSchemaId])
  @@index([authorId])
  @@index([basedOnId])
}

model Conversation {
  id               String           @id @default(cuid())
  trackerSchemaId  String
  title            String?
  mode             ConversationMode @default(BUILDER)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  trackerSchema    TrackerSchema    @relation(fields: [trackerSchemaId], references: [id], onDelete: Cascade)
  messages         Message[]

  @@index([trackerSchemaId])
}

model Message {
  id                    String       @id @default(cuid())
  conversationId        String
  role                  Role
  content               String
  trackerSchemaSnapshot Json?
  managerData           Json?
  createdAt             DateTime     @default(now())
  conversation          Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolCalls             ToolCall[]

  @@index([conversationId])
}

enum ToolCallStatus {
  pending
  running
  done
  error
}

model ToolCall {
  id          String         @id @default(cuid())
  messageId  String
  message    Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  purpose     String         // "validation" | "calculation"
  fieldPath   String
  description String
  status      ToolCallStatus @default(pending)
  error       String?
  result      Json?          // resolved expr or validation rule payload for audit
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([messageId])
}
